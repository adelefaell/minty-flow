{
  "name": "minty-flow",
  "main": "index.ts",
  "version": "1.0.4",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "types": "tsc --noEmit",
    "prepare": "husky",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:fix-unsafe": "biome check --write --unsafe",
    "android:usb": "node ./scripts/run-android-usb.mts",
    "structure": "node ./scripts/generate-structure.mts",
    "unused-styles": "node ./scripts/find-unused-styles.mts",
    "check-i18n-keys": "node ./scripts/check-missing-i18n-keys.mts",
    "build:icons:filled": "svgr --out-dir src/components/icons/filled src/assets/tabler-icons/filled ",
    "build:icons:outline": "svgr --out-dir src/components/icons/outline src/assets/tabler-icons/outline"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@nozbe/watermelondb": "^0.28.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/native": "^7.1.8",
    "@shopify/react-native-skia": "^2.4.18",
    "date-fns": "^4.1.0",
    "expo": "^55.0.6",
    "expo-blur": "~55.0.9",
    "expo-build-properties": "^55.0.9",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-contacts": "~55.0.8",
    "expo-device": "~55.0.9",
    "expo-document-picker": "~55.0.8",
    "expo-file-system": "^55.0.11",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-image-picker": "^55.0.12",
    "expo-intent-launcher": "^55.0.8",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.8",
    "expo-localization": "~55.0.8",
    "expo-location": "~55.1.2",
    "expo-navigation-bar": "^55.0.8",
    "expo-notifications": "~55.0.12",
    "expo-router": "~55.0.5",
    "expo-sensors": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-updates": "^55.0.13",
    "expo-web-browser": "~55.0.9",
    "i18next": "^25.8.13",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.68.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.83.2",
    "react-native-enriched": "^0.4.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "^4.1.2",
    "react-native-nitro-modules": "^0.33.2",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-restart": "^0.0.27",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-unistyles": "^3.0.20",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "rrule": "^2.8.1",
    "uuid": "^13.0.0",
    "victory-native": "^41.20.2",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.28.6",
    "@biomejs/biome": "^2.3.14",
    "@nozbe/simdjson": "^3.9.4",
    "@react-native-community/cli": "latest",
    "@svgr/cli": "^8.1.0",
    "@types/react": "~19.2.14",
    "husky": "^9.1.7",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@nozbe/watermelondb",
          "@nozbe/simdjson",
          "react-native-restart"
        ]
      }
    }
  }
}
